modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["lsof", "zip", "supabase-cli", "stripe-cli", "nano"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "echo \"skip build\""]
run = ["sh", "-c", "ls -la dist dist/index.cjs || true; git rev-parse --short HEAD || true; node dist/index.cjs"]
publicDir = "dist/public"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173
[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
mockupState = "FULLSTACK"
integrations = ["stripe:2.0.0"]
expertMode = true

[userenv]

[userenv.shared]
MEDIA_PROVIDER = "supabase"
